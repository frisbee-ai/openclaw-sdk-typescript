{
  "name": "openclaw-sdk",
  "version": "2026.3.13",
  "description": "OpenClaw SDK for TypeScript/JavaScript",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./protocol": {
      "types": "./dist/esm/protocol.d.ts",
      "import": "./dist/esm/protocol.js",
      "require": "./dist/cjs/protocol.js",
      "default": "./dist/esm/protocol.js"
    },
    "./browser": {
      "default": "./dist/browser/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "esm": ["dist/esm/index.d.ts"],
      "default": ["dist/esm/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openclaw": "2026.3.13"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "esbuild": "0.27.4",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "madge": "8.0.0",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "keywords": [
    "openclaw",
    "sdk"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
