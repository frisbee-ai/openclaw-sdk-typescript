{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "../../src/index.js": ["./src/index.ts"],
      "../../src/*": ["./src/*"]
    }
  },
  "include": ["docs/examples/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
