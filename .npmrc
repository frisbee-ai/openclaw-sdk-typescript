# npm publish configuration
# https://docs.npmjs.com/cli/v9/configuring-npm/npmrc

# Use the public npm registry
registry=https://registry.npmjs.org/

# Always use semantic versions in tags
tag-version-prefix=v

# Save exact version (not recommended for libraries, commented out)
# save-exact=true

# Use package-lock.json
package-lock=true

# Prohibit publishing of new packages without OTP (two-factor auth)
# Uncomment if you have 2FA enabled on your npm account
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Prohibit publishing to public registry without verification
# Requires npm verify and OTP for publish
# require-scripts=false
